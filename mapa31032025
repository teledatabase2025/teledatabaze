<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<title>Mapa pohybu 31. 3. 2026</title>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css">

<style>
body { margin:0; font-family:Arial; background:#f4f4f4; }

.topbar {
  background:#b71c1c;
  color:white;
  height:80px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:26px;
}

.container {
  max-width:1100px;
  margin:30px auto;
  background:white;
  border-radius:8px;
  padding:30px;
}

#map { height:520px; margin-top:20px; }
</style>
</head>

<body>

<div class="topbar">Interní databáze lokalizace zařízení</div>

<div class="container">

<h1>Telefonní číslo: 723 854 5516</h1>

<div id="map"></div>

</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
const records = [
["0:00","50.0797N, 14.4484E"],
["7:00","50.0754N, 14.4527E"],
["9:20","50.0735N, 14.4454E"],
["10:40","50.0719N, 14.4459E"],
["13:40","50.0699N, 14.4514E"],
["15:40","50.0663N, 14.4556E"],
["16:00","50.0654N, 14.4554E"]
];

function parse(c){
 let m=c.match(/([\d.]+)N,\s*([\d.]+)E/);
 return [parseFloat(m[1]), parseFloat(m[2])];
}

const map=L.map("map").setView([50.07,14.45],13);

L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);

const route=records.map(r=>parse(r[1]));

L.polyline(route,{color:"#b71c1c",weight:4}).addTo(map);

records.forEach((r,i)=>{
 L.circleMarker(parse(r[1]),{
  radius: i==records.length-1?8:6,
  color:"#b71c1c",
  fillColor:i==records.length-1?"#1b8f3a":"#b71c1c",
  fillOpacity:0.9
 }).addTo(map).bindPopup(`${r[0]}<br>${r[1]}`);
});

map.fitBounds(route);
</script>

</body>
</html>
